rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /leagues/{leagueId} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.email in [
          "assencarlos2007@gmail.com",
          "Santinotamer.7@gmail.com"
        ];
    }
  }
}
