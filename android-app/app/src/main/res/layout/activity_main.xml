<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A">

    <FrameLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#050505">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:alpha="0.82"
            android:contentDescription="@string/app_name"
            android:scaleType="centerCrop"
            android:src="@drawable/liga_scc_splash" />

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#7A050505" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="28dp">

            <ImageView
                android:id="@+id/loadingLogo"
                android:layout_width="210dp"
                android:layout_height="210dp"
                android:adjustViewBounds="true"
                android:background="#22000000"
                android:contentDescription="@string/app_name"
                android:padding="8dp"
                android:scaleType="fitCenter"
                android:src="@drawable/liga_scc_logo" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center"
                android:letterSpacing="0.08"
                android:text="LIGA SCC"
                android:textAllCaps="true"
                android:textColor="#F5F3EF"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="24dp"
                android:gravity="center"
                android:letterSpacing="0.08"
                android:text="COMPETITIVIDAD AL MAXIMO"
                android:textAllCaps="true"
                android:textColor="#E1DCD4"
                android:textSize="12sp" />

            <ProgressBar
                android:id="@+id/loadingBar"
                style="?android:attr/progressBarStyleLarge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:indeterminate="true" />

            <TextView
                android:id="@+id/loadingText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Abriendo LIGA SCC..."
                android:textColor="#F5F3EF"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/launchHelperText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:textColor="#D7D1C7"
                android:textSize="13sp" />

            <Button
                android:id="@+id/openLeagueButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:backgroundTint="#F5F3EF"
                android:paddingLeft="22dp"
                android:paddingTop="12dp"
                android:paddingRight="22dp"
                android:paddingBottom="12dp"
                android:text="Abrir Liga SCC"
                android:textAllCaps="false"
                android:textColor="#050505" />
        </LinearLayout>
    </FrameLayout>

</FrameLayout>
